{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=ParkingLotDB;Username=postgres;Password=__DB_PASSWORD__"
  },
  "Jwt": {
    "Key": "__JWT_KEY__",
    "Issuer": "ParkEase.AuthService",
    "Audience": "ParkEase.Client"
  },
  "AWS": {
    "AccessKey": "__AWS_ACCESS_KEY__",
    "SecretKey": "__AWS_SECRET_KEY__",
    "Region": "us-east-1",
    "S3": {
      "BucketName": "amz-harsh-parkease"
    }
  },
  "RabbitMQ": {
    "Url": "__RABBITMQ_URL__",
    "Queues": {
      "ParkingLotImageUpload": "parkinglot.image.upload"
    }
  },
  "AllowedHosts": "*"
}