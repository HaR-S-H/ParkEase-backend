{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "https://gilded-chaja-6d09f4.netlify.app",
      "http://localhost:3000",
      "http://localhost:4200"
    ]
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/api/v1/auth/{**catch-all}" }
      },
      "booking-route": {
        "ClusterId": "booking-cluster",
        "Match": { "Path": "/api/v1/bookings/{**catch-all}" }
      },
      "parking-lot-route": {
        "ClusterId": "parking-lot-cluster",
        "Match": { "Path": "/api/v1/lots/{**catch-all}" }
      },
      "spot-route": {
        "ClusterId": "spot-cluster",
        "Match": { "Path": "/api/v1/spots/{**catch-all}" }
      },
      "payment-route": {
        "ClusterId": "payment-cluster",
        "Match": { "Path": "/api/v1/payments/{**catch-all}" }
      },
      "vehicle-route": {
        "ClusterId": "vehicle-cluster",
        "Match": { "Path": "/api/v1/vehicles/{**catch-all}" }
      },
      "notification-route": {
        "ClusterId": "notification-cluster",
        "Match": { "Path": "/api/v1/notifications/{**catch-all}" }
      },
      "notification-hub-route": {
        "ClusterId": "notification-cluster",
        "Match": { "Path": "/hubs/notifications/{**catch-all}" }
      },
      "analytics-route": {
        "ClusterId": "analytics-cluster",
        "Match": { "Path": "/api/v1/analytics/{**catch-all}" }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-service": { "Address": "https://parkease-backend-authservice.onrender.com/" }
        }
      },
      "booking-cluster": {
        "Destinations": {
          "booking-service": { "Address": "https://parkease-bookingservice.onrender.com/" }
        }
      },
      "parking-lot-cluster": {
        "Destinations": {
          "parking-lot-service": { "Address": "https://parkease-backend-parkinglotservice.onrender.com/" }
        }
      },
      "spot-cluster": {
        "Destinations": {
          "spot-service": { "Address": "https://parkease-backend-parkingspotservice.onrender.com/" }
        }
      },
      "payment-cluster": {
        "Destinations": {
          "payment-service": { "Address": "https://parkease-paymentservice.onrender.com/" }
        }
      },
      "vehicle-cluster": {
        "Destinations": {
          "vehicle-service": { "Address": "https://parkease-vehicleservice.onrender.com/" }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "notification-service": { "Address": "https://parkease-backend-notificationservice.onrender.com/" }
        }
      },
      "analytics-cluster": {
        "Destinations": {
          "analytics-service": { "Address": "https://parkease-analyticsservice.onrender.com/" }
        }
      }
    }
  },
  "AllowedHosts": "*"
}
