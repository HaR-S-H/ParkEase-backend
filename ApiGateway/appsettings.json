{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "http://localhost:59154",
      "http://localhost:3000",
      "http://localhost:8080",
      "http://127.0.0.1:4200",
      "http://127.0.0.1:59154"
    ]
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/v1/auth/{**catch-all}"
        }
      },
      "booking-route": {
        "ClusterId": "booking-cluster",
        "Match": {
          "Path": "/api/v1/bookings/{**catch-all}"
        }
      },
      "parking-lot-route": {
        "ClusterId": "parking-lot-cluster",
        "Match": {
          "Path": "/api/v1/lots/{**catch-all}"
        }
      },
      "spot-route": {
        "ClusterId": "spot-cluster",
        "Match": {
          "Path": "/api/v1/spots/{**catch-all}"
        }
      },
      "payment-route": {
        "ClusterId": "payment-cluster",
        "Match": {
          "Path": "/api/v1/payments/{**catch-all}"
        }
      },
      "vehicle-route": {
        "ClusterId": "vehicle-cluster",
        "Match": {
          "Path": "/api/v1/vehicles/{**catch-all}"
        }
      },
      "notification-route": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/api/v1/notifications/{**catch-all}"
        }
      },
      "notification-hub-route": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/hubs/notifications/{**catch-all}"
        }
      },
      "analytics-route": {
        "ClusterId": "analytics-cluster",
        "Match": {
          "Path": "/api/v1/analytics/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-service": {
            "Address": "http://127.0.0.1:5243"
          }
        }
      },
      "booking-cluster": {
        "Destinations": {
          "booking-service": {
            "Address": "http://127.0.0.1:5246"
          }
        }
      },
      "parking-lot-cluster": {
        "Destinations": {
          "parking-lot-service": {
            "Address": "http://127.0.0.1:5244"
          }
        }
      },
      "spot-cluster": {
        "Destinations": {
          "spot-service": {
            "Address": "http://127.0.0.1:5000"
          }
        }
      },
      "payment-cluster": {
        "Destinations": {
          "payment-service": {
            "Address": "http://127.0.0.1:5250"
          }
        }
      },
      "vehicle-cluster": {
        "Destinations": {
          "vehicle-service": {
            "Address": "http://127.0.0.1:5252"
          }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "notification-service": {
            "Address": "http://127.0.0.1:5254"
          }
        }
      },
      "analytics-cluster": {
        "Destinations": {
          "analytics-service": {
            "Address": "http://127.0.0.1:5256"
          }
        }
      }
    }
  },
  "AllowedHosts": "*"
}
