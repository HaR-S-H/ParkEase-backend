{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=AuthDB;Username=postgres;Password=__DB_PASSWORD__"
  },
  "Jwt": {
    "Key": "__JWT_KEY__",
    "Issuer": "ParkEase.AuthService",
    "Audience": "ParkEase.Client"
  },
  "GoogleAuth": {
    "ClientId": "your-google-client-id.apps.googleusercontent.com"
  },
  "AWS": {
    "AccessKey": "__AWS_ACCESS_KEY__",
    "SecretKey": "__AWS_SECRET_KEY__",
    "Region": "us-east-1",
    "S3": {
      "BucketName": "amz-harsh-parkease"
    }
  },
  "App": {
    "BaseUrl": "https://localhost:5001"
  },
  "Mail": {
    "From": {
      "Email": "anantgita108@gmail.com",
      "Name": "ParkEase"
    },
    "Smtp": {
      "Host": "smtp.gmail.com",
      "Port": "587",
      "Username": "__SMTP_USERNAME__",
      "Password": "__SMTP_PASSWORD__"
    },
    "VerificationUrlTemplate": "https://localhost:5001/api/v1/auth/verify-email?email={email}&token={token}"
  },
  "RabbitMQ": {
    "Url": "__RABBITMQ_URL__",
    "Queues": {
      "EmailVerification": "auth.email.verification",
      "ProfilePictureUpload": "auth.profile.picture.upload",
      "ForgotPassword": "auth.forgot.password"
    }
  },
  "AllowedHosts": "*"
}
