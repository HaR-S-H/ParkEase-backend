  "item": [
    {
      "name": "Auth Service",
      "item": [
        {
          "name": "POST Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "multipart/form-data" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "FullName", "value": "John Doe", "type": "text" },
                { "key": "Email", "value": "john@example.com", "type": "text" },
                { "key": "Password", "value": "Password123!", "type": "text" },
                { "key": "Phone", "value": "9999999999", "type": "text" },
                { "key": "Role", "value": "USER", "type": "text" },
                { "key": "VehiclePlate", "value": "MH12AB1234", "type": "text" }
              ]
            },
            "url": "{{apiGatewayUrl}}/api/v1/auth/register"
          }
        },
        {
          "name": "POST Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) pm.environment.set('accessToken', json.token);",
                  "if (json.refreshToken) pm.environment.set('refreshToken', json.refreshToken);",
                  "if (json.user && json.user.userId !== undefined) pm.environment.set('userId', String(json.user.userId));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": "{{apiGatewayUrl}}/api/v1/auth/login"
          }
        },
        {
          "name": "POST Google Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) pm.environment.set('accessToken', json.token);",
                  "if (json.refreshToken) pm.environment.set('refreshToken', json.refreshToken);",
                  "if (json.user && json.user.userId !== undefined) pm.environment.set('userId', String(json.user.userId));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idToken\": \"paste-google-id-token\",\n  \"role\": \"USER\",\n  \"phone\": \"9999999999\",\n  \"vehiclePlate\": \"MH12AB1234\"\n}"
            },
            "url": "{{apiGatewayUrl}}/api/v1/auth/google-login"
          }
        },
        {
          "name": "POST Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) pm.environment.set('accessToken', json.token);",
                  "if (json.refreshToken) pm.environment.set('refreshToken', json.refreshToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{apiGatewayUrl}}/api/v1/auth/refresh"
          }
        },
        {
          "name": "GET Verify Email",
          "request": {
            "method": "GET",
            "url": "{{apiGatewayUrl}}/api/v1/auth/verify-email?email={{email}}&token={{verificationToken}}"
          }
        },
        {
          "name": "POST Resend Verification",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\"\n}"
            },
            "url": "{{apiGatewayUrl}}/api/v1/auth/resend-verification"
          }
        },
        {
          "name": "POST Forgot Password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
