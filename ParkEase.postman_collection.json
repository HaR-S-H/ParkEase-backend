{
  "info": {
    "_postman_id": "5d2f6a11-4d7d-4de2-9f1f-0d6c2a7c3b61",
    "name": "ParkEase Services",
    "description": "Import this collection and use the ParkEase API Gateway as the single base URL. Login first to populate the access token. Protected endpoints use bearer auth inherited from the collection. Notification hub endpoints are not included because they are SignalR-specific.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    { "key": "apiGatewayUrl", "value": "http://localhost:5000" },
    { "key": "frontendUrl", "value": "http://localhost:3000" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
